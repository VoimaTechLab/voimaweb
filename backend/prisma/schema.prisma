generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum MessageStatus {
  unread
  read
  replied
  archived
}

enum SubscriberStatus {
  active
  unsubscribed
}

enum StoryStatus {
  pending
  approved
  rejected
}

enum EventStatus {
  draft
  published
}

model Admin {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         Role           @default(EDITOR)
  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  refreshTokens RefreshToken[]
  activities    ActivityLog[]

  @@map("admins")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  adminId   String
  admin     Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([adminId])
  @@map("refresh_tokens")
}

model Message {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    MessageStatus @default(unread)
  createdAt DateTime      @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("messages")
}

model NewsletterSubscriber {
  id           String           @id @default(cuid())
  email        String           @unique
  status       SubscriberStatus @default(active)
  source       String?          @default("website")
  subscribedAt DateTime         @default(now())

  @@index([subscribedAt])
  @@map("newsletter_subscribers")
}

model WaitlistUser {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?
  location  String?
  role      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("waitlist_users")
}

model Story {
  id              String      @id @default(cuid())
  contributorName String
  email           String?
  location        String?
  title           String?
  story           String
  image           String?
  status          StoryStatus @default(pending)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@map("stories")
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String
  location    String?
  eventDate   DateTime?
  image       String?
  status      EventStatus @default(draft)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@map("events")
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String   // message | waitlist | story | newsletter | blog | event | auth
  text      String
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("activity_logs")
}

// Single-row site configuration (key: "site")
model Setting {
  id        String   @id @default("site")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("settings")
}


model VolunteerApplication {
  id         String   @id @default(cuid())
  fullName   String
  email      String
  motivation String
  status     String   @default("new")
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@map("volunteer_applications")
}