NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

CLIENT_URL=http://localhost:3000
COOKIE_DOMAIN=localhost

# --- Neon PostgreSQL (pooled connection) ---
# Use the *pooled* string for the app, *direct* for migrations if needed.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/voima?sslmode=require"

JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=voima

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Voima Initiative <no-reply@voima.org>"
ADMIN_NOTIFY_EMAIL=admin@voima.org

# Sanity (backend read-only counts)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_READ_TOKEN=

SEED_ADMIN_NAME=Emmanuel Dey
SEED_ADMIN_EMAIL=admin@voima.org
SEED_ADMIN_PASSWORD=ChangeMe123!